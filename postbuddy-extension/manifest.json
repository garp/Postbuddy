{
  "version": "2.5.3",
  "manifest_version": 3,
  "name": "Postbuddy",
  "description": "This is an auto comment Chrome Extension made for social media engagement.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "js/index.html",
    "default_title": "React Chrome Extension"
  },  
  "host_permissions": [
    "https://api.postbuddy.ai/*",
    "https://postbuddy-back-dev.xctzle.easypanel.host/*",
    "http://localhost:4001/*",
    "*://www.linkedin.com/*",
    "*://www.instagram.com/*",
    "*://web.whatsapp.com/*",
    "*://www.facebook.com/*",
    "*://www.youtube.com/*",
    "*://x.com/*",
    "*://www.reddit.com/*",
    "https://postbuddy.ai/*"
  ],
  "icons": {
    "128": "icons/128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://postbuddy.ai/*"],
      "js": ["js/postbuddy.js"]
    },
    {
      "matches": ["*://www.linkedin.com/*"],
      "js": ["js/contentScript.js"]
    },
    {
      "matches": ["*://www.instagram.com/*"],
      "js": ["js/instaContentScript.js"]
    },
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["js/whatsappScript.js"]
    },
    {
      "matches": ["*://www.facebook.com/*"],
      "js": ["js/fbContentScript.js"]
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["js/ytContentScript.js"]
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["js/xContentScript.js"]
    },
    {
      "matches": ["*://www.reddit.com/*"],
      "js": ["js/reddit.js"]
    },
    {
      "matches": ["*://outlook.office.com/*"],
      "js": ["js/outlookContentScript.js"]
    }
  ]
}
